# ── Node.js ──────────────────────────────────
**/node_modules/
**/npm-debug.log*

# ── Environment files (NEVER commit these) ───
**/.env
**/.env.local
**/.env.*.local

# ── React build output ────────────────────────
frontend/build/

# ── Editors ──────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ── Kubernetes / Helm ────────────────────────
*.kubeconfig
kubeconfig

# ── Terraform ────────────────────────────────
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/.terraform.lock.hcl

# ── Logs ─────────────────────────────────────
*.log
**/logs/

# ── Test coverage ─────────────────────────────
**/coverage/


# Terraform state — never commit
*.tfstate
*.tfstate.*
*.tfstate.backup
 
# Terraform vars — contains secrets
terraform.tfvars
 
# Terraform internals
.terraform/
.terraform.lock.hcl
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
 